{
  "expo": {
    "name": "Dastiyor",
    "slug": "dastiyor",
    "owner": "balwinder98",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dastiyor",
    "icon": "./assets/icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dastiyor.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Dastiyor sends notifications about new messages, task updates, and responses to your offers."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.dastiyor.app",
      "versionCode": 1,
      "permissions": [],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#2563EB"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f9fc73fa-401e-44a2-87ce-58aa4e7b5498"
      },
      "privacyPolicyUrl": "https://dastiyor.com/privacy",
      "termsOfServiceUrl": "https://dastiyor.com/terms"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "POSTGRES_PRISMA_URL",
        "POSTGRES_URL_NON_POOLING",
        "POSTGRES_URL",
        "POSTGRES_HOST",
        "POSTGRES_USER",
        "POSTGRES_PASSWORD",
        "POSTGRES_DATABASE",
        "DATABASE_URL",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "SUPABASE_SECRET_KEY",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_JWT_SECRET",
        "JWT_SECRET",
        "BREVO_API_KEY",
        "BREVO_FROM_EMAIL",
        "BREVO_FROM_NAME",
        "BREVO_SMS_SENDER",
        "MESSAGEBIRD_API_KEY",
        "SMARTPAY_API_URL",
        "SMARTPAY_MERCHANT_ID",
        "SMARTPAY_SECRET_KEY",
        "VAPID_PRIVATE_KEY",
        "VAPID_SUBJECT",
        "NEXT_PUBLIC_VAPID_PUBLIC_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}

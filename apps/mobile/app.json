{
  "expo": {
    "name": "Dastiyor",
    "slug": "dastiyor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dastiyor",
    "platforms": ["ios", "android"],

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000,
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID"
    },

    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dastiyor.app",
      "buildNumber": "1",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },

    "android": {
      "package": "com.dastiyor.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },

    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-updates"
    ],

    "extra": {
      "privacyPolicyUrl": "https://dastiyor.com/privacy",
      "termsOfServiceUrl": "https://dastiyor.com/terms",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },

    "experiments": {
      "typedRoutes": true
    }
  }
}

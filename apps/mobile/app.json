{
  "expo": {
    "name": "Dastiyor",
    "slug": "dastiyor",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dastiyor",
    "platforms": ["ios", "android"],
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dastiyor.app"
    },
    "android": {
      "package": "com.dastiyor.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-splash-screen"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
